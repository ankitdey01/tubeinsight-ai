# ─── API Keys ─────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
OPENROUTER_API_KEY=your_openrouter_key_here  # Used for LLM requests when OLLAMA_BASE_URL is not set

# ─── Local LLM (Ollama) ───────────────────────────────────────────────────────
# Set below to use local Ollama instead of OpenRouter
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# ─── Model Config ─────────────────────────────────────────────────────────────
LLM_MODEL=anthropic/claude-3.5-sonnet:beta  # OpenRouter model ID

# ─── Data & Storage ───────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/vectorstore
CACHE_DIR=./data/processed
RAW_DATA_DIR=./data/raw

# ─── Ingestion Limits ─────────────────────────────────────────────────────────
MAX_COMMENTS_PER_VIDEO=100
MAX_VIDEOS_PER_CHANNEL=10

# ─── App Config ───────────────────────────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=INFO